private List<Membership> getDisplayableMemberships(List<Membership> memberships) {

if (CollectionUtils.isEmpty(memberships)) {
return Collections.emptyList();
}

// 1️⃣ Filter hearing / withdrawn / future active memberships
List<Membership> filteredMemberships = memberships.stream()
.filter(Objects::nonNull)
.filter(m ->
(m.getIsCoverageWithdrawn() == null ||
BooleanUtils.isFalse(m.getIsCoverageWithdrawn()))
)
.filter(m ->
(m.getIsFutureActive() == null ||
BooleanUtils.isFalse(m.getIsFutureActive()))
)
.toList(); // preserves original order

if (CollectionUtils.isEmpty(filteredMemberships)) {
return filteredMemberships;
}

// 2️⃣ Get Medical + Non-MA memberships
List<Membership> nonMaMedicalMemberships =
filteredMemberships.stream()
.filter(m ->
ObjectUtils.equals(m.getCoverageType(), CoverageType.MEDICAL) &&
BooleanUtils.isFalse(m.getMAContractIndicator())
)
.toList();

// 3️⃣ If NO non-MA medical memberships found → show only MA memberships
if (CollectionUtils.isEmpty(nonMaMedicalMemberships)) {
filteredMemberships =
filteredMemberships.stream()
.filter(m -> BooleanUtils.isTrue(m.getMAContractIndicator()))
.toList();
}

return filteredMemberships;
}
}
