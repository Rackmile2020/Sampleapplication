export async function reloadRemoteEntry(
  remoteUrl: string,
  remoteName: string
): Promise<void> {

  // 1️⃣ Remove existing container
  if ((window as any)[remoteName]) {
    delete (window as any)[remoteName];
  }

  // 2️⃣ Remove old script tag
  const oldScript = document.querySelector(
    `script[src="${remoteUrl}"]`
  ) as HTMLScriptElement;

  if (oldScript) {
    oldScript.remove();
  }

  // 3️⃣ VERY IMPORTANT: reset webpack share scope
  if ((window as any).__webpack_share_scopes__) {
    delete (window as any).__webpack_share_scopes__.default;
  }

  // 4️⃣ Re-init sharing
  // @ts-ignore
  await __webpack_init_sharing__('default');

  // 5️⃣ Load remote again
  await loadRemoteEntry(remoteUrl, remoteName);
}
